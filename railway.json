{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && pip install -r requirements.txt && python manage.py collectstatic --noinput"
  },
  "deploy": {
    "startCommand": "cd backend && gunicorn rxsignal.wsgi --workers 2 --bind 0.0.0.0:$PORT --timeout 60",
    "healthcheckPath": "/api/events/?drug=aspirin",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
